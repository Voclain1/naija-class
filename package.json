{
  "name": "school-kit",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@school-kit/api",
    "dev:web": "turbo run dev --filter=@school-kit/web",
    "dev:mobile": "turbo run dev --filter=@school-kit/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @school-kit/db migrate",
    "db:reset": "pnpm --filter @school-kit/db migrate:reset",
    "db:seed": "pnpm --filter @school-kit/db seed",
    "db:studio": "pnpm --filter @school-kit/db studio",
    "ai:eval": "pnpm --filter @school-kit/ai eval",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
