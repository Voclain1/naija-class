{
  "name": "@school-kit/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tenant-client": {
      "types": "./dist/tenant-client.d.ts",
      "default": "./dist/tenant-client.js"
    }
  },
  "files": ["dist", "generated"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "echo 'lint placeholder'",
    "test": "echo 'test placeholder'",
    "generate": "dotenv -e ../../.env -- prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "migrate:reset": "dotenv -e ../../.env -- prisma migrate reset --force",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "prisma": "dotenv -e ../../.env -- prisma",
    "seed": "dotenv -e ../../.env -- prisma db seed",
    "dev:seed": "dotenv -e ../../.env -- tsx prisma/dev-seed.ts",
    "prune-smoke": "dotenv -e ../../.env -- sh -c 'psql \"$DIRECT_URL\" -f ../../scripts/prune-smoke-schools.sql'",
    "clean": "rm -rf dist generated"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@school-kit/types": "workspace:*"
  },
  "devDependencies": {
    "@school-kit/config": "workspace:*",
    "@types/node": "^22.10.0",
    "argon2": "^0.41.1",
    "dotenv-cli": "^7.4.4",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
