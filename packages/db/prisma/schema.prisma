// School Kit — Prisma schema (Phase 0)
//
// Models below mirror docs/modules/phase-0.md verbatim. Tenancy is enforced at
// the Postgres layer via RLS (see packages/db/prisma/policies/phase-0.sql) and
// at the application layer via withTenant() (see src/tenant-client.ts).

generator client {
  provider        = "prisma-client-js"
  // Generated client lives inside this package, gitignored. Sits as a
  // sibling of src/ so that compiled dist/*.js can require it via the same
  // relative path source uses (../generated/client).
  output          = "../generated/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // Migrations run as the privileged DB owner (school_kit). The runtime client
  // uses `url` and connects as `app_user`, which cannot bypass RLS.
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector"), uuidOssp(map: "uuid-ossp")]
}

// ---------- Tenancy ----------

model School {
  id             String       @id @default(uuid())
  name           String
  slug           String       @unique // for subdomains: <slug>.schoolkit.ng
  motto          String?
  logoUrl        String?      @map("logo_url")
  address        String?
  phone          String?
  email          String?
  primaryColor   String?      @map("primary_color")
  status         SchoolStatus @default(ONBOARDING)
  onboardingStep Int          @default(0) @map("onboarding_step")
  ndprConsent    Boolean      @default(false) @map("ndpr_consent")
  ndprConsentAt  DateTime?    @map("ndpr_consent_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  branches    Branch[]
  users       User[]
  invitations Invitation[]

  @@map("schools")
}

enum SchoolStatus {
  ONBOARDING
  ACTIVE
  SUSPENDED
  ARCHIVED
}

model Branch {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  name      String
  address   String?
  isMain    Boolean  @default(false) @map("is_main")
  createdAt DateTime @default(now()) @map("created_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("branches")
}

// ---------- Identity ----------

model User {
  id            String    @id @default(uuid())
  schoolId      String    @map("school_id")
  email         String?   @unique
  phone         String?   @unique
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  passwordHash  String?   @map("password_hash")
  isActive      Boolean   @default(true) @map("is_active")
  emailVerified Boolean   @default(false) @map("email_verified")
  phoneVerified Boolean   @default(false) @map("phone_verified")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  school   School     @relation(fields: [schoolId], references: [id])
  roles    UserRole[]
  sessions Session[]

  // Phase 1 / Slice 3 — back-relation to ClassArm.classTeacherId.
  // Named relation because slice 10's teacher-subject assignment will add a
  // second User-to-ClassArm edge through TeacherAssignment; Prisma requires
  // a relation name once two edges exist between the same two models.
  classTeacherArms ClassArm[] @relation("ClassTeacherArms")

  // Phase 1 / Slice 10 — 1:1 HR profile for users who hold the teacher role.
  // Optional because most users (owner, admin) never get one, and a teacher
  // exists as a User the moment they accept their invitation; the profile is
  // created explicitly by an admin afterwards (Q2 lifecycle, locked
  // 2026-05-30 — no auto-create on accept).
  teacherProfile TeacherProfile?

  @@index([schoolId])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  schoolId    String?  @map("school_id") // null = system role (seeded)
  key         String // 'owner', 'admin', 'teacher', etc.
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  permissions Json     @default("[]") // string[] of permission keys, or ["*"]
  createdAt   DateTime @default(now()) @map("created_at")

  users UserRole[]

  @@unique([schoolId, key])
  @@map("roles")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Invitation {
  id         String    @id @default(uuid())
  schoolId   String    @map("school_id")
  email      String?
  phone      String?
  firstName  String?   @map("first_name")
  lastName   String?   @map("last_name")
  roleKey    String    @map("role_key")
  tokenHash  String    @unique @map("token_hash")
  invitedBy  String    @map("invited_by")
  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("invitations")
}

model AuditLog {
  id         String   @id @default(uuid())
  schoolId   String?  @map("school_id")
  userId     String?  @map("user_id")
  action     String // e.g. 'school.update', 'user.invite', 'academic-year.create'
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([schoolId, createdAt])
  @@map("audit_logs")
}

// ---------- Phase 1 / Slice 1 — Academic structure (year + term) ----------
//
// First Phase 1 slice. Two tables, both school-scoped, both under FORCE RLS.
// "Current year" / "current term" is modelled as an isCurrent flag enforced
// by partial unique indexes (added in the migration's raw SQL because
// Prisma's @@unique cannot express WHERE clauses). The service layer
// cascades setCurrentTerm → academic_year.is_current; that invariant is the
// only one the DB does not enforce, and the terms.service spec asserts it.

model AcademicYear {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  label     String // e.g. "2025/2026" — unique per school
  startDate DateTime @map("start_date") @db.Date // calendar dates, not moments — see CLAUDE.md
  endDate   DateTime @map("end_date") @db.Date
  isCurrent Boolean  @default(false) @map("is_current")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  terms       Term[]
  enrollments Enrollment[] // Phase 1 / Slice 9 back-relation.

  @@unique([schoolId, label])
  @@index([schoolId])
  @@index([schoolId, isCurrent])
  @@map("academic_years")
}

model Term {
  id             String   @id @default(uuid())
  schoolId       String   @map("school_id")
  academicYearId String   @map("academic_year_id")
  sequence       Int // 1 | 2 | 3 — unique within a year
  name           String // "First Term", "Second Term", "Third Term"
  startDate      DateTime @map("start_date") @db.Date
  endDate        DateTime @map("end_date") @db.Date
  isCurrent      Boolean  @default(false) @map("is_current")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  enrollments  Enrollment[] // Phase 1 / Slice 9 back-relation.

  @@unique([academicYearId, sequence])
  @@index([schoolId])
  @@index([schoolId, isCurrent])
  @@map("terms")
}

// ---------- Phase 1 / Slice 2 — Class levels ----------
//
// Hybrid model: every new school is auto-seeded with the 14 standard Nigerian
// levels (KG 1/2, Primary 1–6, JSS 1–3, SSS 1–3) inside the signup
// transaction (see apps/api/src/modules/auth/auth.service.ts → signupOwner).
// Schools can then add custom levels, edit names, or toggle isActive.
//
// `code` is the stable per-school identifier (matching the seed) and backs
// the uniqueness constraint; `name` is the human-facing label and can be
// renamed freely. `orderIndex` drives sort order in the UI; duplicates are
// tolerated for schools that interleave custom levels (sort tie-breaks on
// name ASC). No partial unique index here — there is no "current level"
// concept; the current academic year/term carries that semantic.

model ClassLevel {
  id         String     @id @default(uuid())
  schoolId   String     @map("school_id")
  name       String // "KG 1", "Primary 4" — human-facing; renamable
  code       String // "kg1", "pri4" — stable per-school identifier (unique)
  stage      ClassStage // NURSERY | PRIMARY | JSS | SSS — coarse grouping
  orderIndex Int        @map("order_index") // sort order; seeded 1..14
  isActive   Boolean    @default(true) @map("is_active")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  // Phase 1 / Slice 3 back-relations.
  arms          ClassArm[]
  classSubjects ClassSubject[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([schoolId, orderIndex])
  @@map("class_levels")
}

enum ClassStage {
  NURSERY
  PRIMARY
  JSS
  SSS
}

// ---------- Phase 1 / Slice 3 — Class arms, subjects, class-subjects ----------
//
// Three models that complete the academic skeleton. ClassArm is the section
// under a ClassLevel ("JSS 1A", "JSS 1B"); Subject is the school-wide subject
// catalog; ClassSubject is the explicit many-to-many between ClassLevel and
// Subject (curriculum lives at the level, not the arm — all arms of JSS 1
// take the same set of subjects). All three carry their own school_id for
// direct-RLS isolation, matching the slice 1+2 pattern.
//
// classTeacherId on ClassArm references users.id (not teacher_profiles.id —
// that table arrives in slice 10). The dropdown stays empty until teachers
// have accepted invitations; the UI surfaces an "Invite a teacher" CTA per
// the spec risk note (docs/modules/phase-1.md → Risks and gotchas).

model ClassArm {
  id             String   @id @default(uuid())
  schoolId       String   @map("school_id")
  classLevelId   String   @map("class_level_id")
  name           String // "JSS 1A" — human-facing; renamable
  code           String // "jss1-a" — stable per-(school, level) identifier
  capacity       Int? // optional max headcount
  classTeacherId String?  @map("class_teacher_id") // FK → users.id (form teacher)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  classLevel   ClassLevel @relation(fields: [classLevelId], references: [id], onDelete: Cascade)
  classTeacher User?      @relation("ClassTeacherArms", fields: [classTeacherId], references: [id], onDelete: SetNull)
  enrollments  Enrollment[] // Phase 1 / Slice 9 back-relation.

  @@unique([schoolId, classLevelId, code])
  @@index([schoolId])
  @@index([classTeacherId])
  @@map("class_arms")
}

model Subject {
  id        String          @id @default(uuid())
  schoolId  String          @map("school_id")
  name      String // "Mathematics" — human-facing; renamable
  code      String // "math" — stable per-school identifier (unique)
  category  SubjectCategory @default(CORE)
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  classSubjects ClassSubject[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("subjects")
}

enum SubjectCategory {
  CORE
  ELECTIVE
  VOCATIONAL
}

// Explicit join between ClassLevel and Subject. Explicit (not Prisma's
// implicit m-n) because we need our own school_id column for direct-RLS and
// our own `isCore` payload (curriculum metadata: e.g. Maths is core in JSS
// but may be elective in some SSS streams). No updatedAt — link membership
// is binary; toggling isCore is a single UPDATE without history.

model ClassSubject {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  classLevelId String   @map("class_level_id")
  subjectId    String   @map("subject_id")
  isCore       Boolean  @default(true) @map("is_core")
  createdAt    DateTime @default(now()) @map("created_at")

  classLevel ClassLevel @relation(fields: [classLevelId], references: [id], onDelete: Cascade)
  subject    Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([schoolId, classLevelId, subjectId])
  @@index([schoolId])
  @@index([subjectId])
  @@map("class_subjects")
}

// ---------- Phase 1 / Slice 4 — Students ----------
//
// First slice to model actual people. Student is the roster spine: CSV import
// (slices 6-8) and Enrollment (slice 9) both build on this table. The model is
// stripped of every relation that points at models that do not exist yet —
// StudentGuardian (slice 5), Enrollment (slice 9), MasteryRecord +
// AIInteractionLog (slice 12) — those back-relations are added by their own
// slices to keep this one purely additive.
//
// Class membership is intentionally NOT on Student. The spec locks per-term
// Enrollment as the only source of truth (docs/modules/phase-1.md → "Enrollment
// is per-TERM, not per-academic-year"); a denormalised currentClassArmId here
// would drift on every term boundary and break the join shape Phase 2 is built
// around.
//
// dateOfBirth uses @db.Date per CLAUDE.md's "calendar date vs moment" rule
// (also explicitly named in that rule). The spec text shows plain `DateTime`
// — that's a pre-convention oversight from before slice 1 locked the
// convention, reconciled in this slice's docs edit. Plain DateTime is kept
// for admittedAt/withdrawnAt/graduatedAt: those are events (when the
// transition happened), not calendar dates.
//
// admissionNumber is free-text required-unique-per-school (no auto-format,
// no school-configurable scheme in Phase 1 — deferred). The unique constraint
// is the ordinary @@unique form, not a partial index, since there's no
// "current" semantic on Student.

model Student {
  id              String        @id @default(uuid())
  schoolId        String        @map("school_id")
  admissionNumber String        @map("admission_number") // free-text, unique per school
  firstName       String        @map("first_name")
  middleName      String?       @map("middle_name")
  lastName        String        @map("last_name")
  dateOfBirth     DateTime      @map("date_of_birth") @db.Date // calendar date — see CLAUDE.md
  gender          Gender
  photoUrl        String?       @map("photo_url") // string only; upload UI deferred (Phase 2/4)
  address         String?
  phone           String?
  email           String?
  bloodGroup      String?       @map("blood_group")
  medicalNotes   String?       @map("medical_notes")
  religion        String?
  stateOfOrigin   String?       @map("state_of_origin")
  nationality     String        @default("Nigerian")
  status          StudentStatus @default(ACTIVE)
  admittedAt      DateTime      @default(now()) @map("admitted_at") // event moment
  withdrawnAt     DateTime?     @map("withdrawn_at") // event moment
  graduatedAt     DateTime?     @map("graduated_at") // event moment
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Slice 5 adds the StudentGuardian back-relation; slice 9 adds Enrollment.
  // MasteryRecord + AIInteractionLog land in slice 12 when those tables arrive.
  guardians   StudentGuardian[]
  enrollments Enrollment[] // Phase 1 / Slice 9 back-relation.

  @@unique([schoolId, admissionNumber])
  @@index([schoolId])
  @@index([schoolId, status])
  @@index([schoolId, lastName, firstName]) // sorted roster scans
  @@map("students")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  WITHDRAWN
  GRADUATED
  SUSPENDED
}

// ---------- Phase 1 / Slice 5 — Guardians + student-guardian links ----------
//
// Guardian is a school-scoped person record (parent, sibling, NOK, etc.).
// Phase 1 is admin-managed: owners and admins create / edit / link / unlink.
// Parent AUTH and the parent-facing app are Phase 4 — guardians cannot log in
// yet, so there is no User row paired with a Guardian here.
//
// Two design choices worth flagging:
//
//   1. NO unique constraint on (school_id, phone) or (school_id, email). A
//      mother and father commonly share a household phone; a guardian with a
//      shared family inbox may legitimately appear against multiple students
//      under separate records (rare, but real). The (school_id, phone) index
//      backs the link-existing picker; uniqueness would block valid data.
//
//   2. isPrimary on StudentGuardian has no schema-level "only one per
//      student" rule — application enforces it (GuardiansService demotes
//      sibling links inside the same transaction). A partial unique index
//      would be the correct-by-construction guard, but it would also block
//      the demote-then-promote pattern unless wrapped in a DEFERRABLE
//      constraint, which Postgres only supports for UNIQUE on a regular
//      index, not a partial one. The service-layer rule is the only path.
//
// onDelete: Cascade on BOTH FKs of StudentGuardian — deleting a Student or
// a Guardian cleans up the links. Guardian deletion itself is gated by the
// service to refuse hard-delete while links exist, so the cascade is a
// belt-and-braces guard, not the primary unlink path.

model Guardian {
  id           String       @id @default(uuid())
  schoolId     String       @map("school_id")
  firstName    String       @map("first_name")
  lastName     String       @map("last_name")
  relationship Relationship
  phone        String // NOT globally unique — see header comment
  email        String?
  occupation   String?
  employer     String?
  address      String?
  notes        String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  students StudentGuardian[]

  @@index([schoolId])
  @@index([schoolId, phone]) // backs the link-existing picker's phone search
  @@map("guardians")
}

enum Relationship {
  FATHER
  MOTHER
  GUARDIAN
  UNCLE
  AUNT
  GRANDPARENT
  SIBLING
  OTHER
}

model StudentGuardian {
  id         String   @id @default(uuid())
  schoolId   String   @map("school_id") // denormalised for direct RLS
  studentId  String   @map("student_id")
  guardianId String   @map("guardian_id")
  isPrimary  Boolean  @default(false) @map("is_primary")
  canPickup  Boolean  @default(true) @map("can_pickup")
  createdAt  DateTime @default(now()) @map("created_at")

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@unique([studentId, guardianId]) // a guardian cannot link to the same student twice
  @@index([schoolId])
  @@index([guardianId]) // reverse lookup: a guardian's children
  @@map("student_guardians")
}

// ---------- Phase 1 / Slice 6 — CSV import bookkeeping ----------
//
// One row per import attempt. The row is the source of truth for the
// wizard UI; BullMQ's internal job state (waiting/active/failed) is
// implementation detail and NEVER reaches the API consumer. The state
// machine is:
//
//   PENDING ──mapping─▶ VALIDATING ──worker ok──▶ READY ──┐  (commit is slice 7+)
//      │                     │                              ▼
//      │ delete              │ retries exhausted        COMMITTING ─▶ COMPLETED
//      ▼                     ▼
//   (gone)                  FAILED  ◀─────────────────────  (worker fatal)
//
// `sourceFileUrl` is a storage path (driver-agnostic — R2 in prod,
// filesystem in dev) of the form `schools/<schoolId>/imports/<jobId>/source.csv`.
// The StorageService is responsible for constructing this path; the schema
// does not enforce its shape because the path is opaque to Postgres.
//
// `previewSnapshot` holds first 50 good + first 50 bad rows for the UI
// preview only — the full bad-rows download (and the slice-7 error report)
// re-stream the source CSV rather than store all bad rows in JSON, to
// avoid bloating this row for large mostly-bad uploads.
//
// `failedReason` is populated by the FailedJobEvent listener when BullMQ
// exhausts retries, or directly by the worker when it detects an
// unrecoverable error (missing source file, parser fatal, etc.). Surfaced
// to the admin on step 3 of the wizard.
//
// `createdBy` is the userId of the admin who initiated the upload; flows
// into job-data for the worker so audit rows (slice 7 commit) attribute
// to a real user without needing a request context.
//
// SECURITY DEFINER count stays at 4. Every import endpoint is post-
// authentication and post-tenant; the worker establishes tenant context
// from job.data.schoolId via withTenant() — see apps/api/src/common/queue/
// tenant-worker.ts for the wrapper that makes this invariant mechanical.
model ImportJob {
  id              String          @id @default(uuid())
  schoolId        String          @map("school_id")
  type            ImportJobType
  status          ImportJobStatus @default(PENDING)
  sourceFileUrl   String          @map("source_file_url")
  columnMapping   Json?           @map("column_mapping")
  totalRows       Int             @default(0) @map("total_rows")
  validRows       Int             @default(0) @map("valid_rows")
  invalidRows     Int             @default(0) @map("invalid_rows")
  committedRows   Int             @default(0) @map("committed_rows")
  errorReportUrl  String?         @map("error_report_url")
  previewSnapshot Json?           @map("preview_snapshot")
  failedReason    String?         @map("failed_reason")
  createdBy       String          @map("created_by")
  createdAt       DateTime        @default(now()) @map("created_at")
  completedAt     DateTime?       @map("completed_at")

  @@index([schoolId])
  @@index([schoolId, status])
  @@map("import_jobs")
}

enum ImportJobType {
  STUDENTS
  GUARDIANS
  TEACHERS
}

enum ImportJobStatus {
  PENDING
  VALIDATING
  READY
  COMMITTING
  COMPLETED
  FAILED
}

// ---------- Phase 1 / Slice 9 — Enrollment (per-term) ----------
//
// Per-term, not per-academic-year. One row per (school, student, term).
// Why per-term, locked at 2026-05-22 in Phase 1 planning (docs/modules/
// phase-1.md → "Enrollment is per-TERM, not per-academic-year"):
//   - Nigerian schools admit students mid-year. A second-term joiner
//     gets a second-term row and no first-term row — no fudging.
//   - Phase 2's term-scoped features (attendance, CA1/CA2/exam, report
//     cards) join cleanly to Enrollment without a "which arm were they
//     in this term" lookup table.
//   - Mid-year arm transfers manifest as the NEXT term's row in the
//     new arm; the old term's row stays as historical truth.
// Do NOT "simplify" this back to per-year — it breaks the join shape
// Phase 2 is designed around.
//
// academicYearId is denormalised from term.academicYearId for cheap
// "all students enrolled in 2025/2026" roster queries. The service
// layer resolves academicYearId from termId at write time; the API
// never accepts it from a request body. The columns must stay
// consistent — Phase 2 may add a CHECK constraint or trigger; Phase
// 1 keeps it as a service-layer invariant to ship.
//
// Status enum (six values; only ENROLLED + WITHDRAWN have workflows
// in slice 9, the others reachable via manual PATCH — see slice-9
// scope decision):
//   - ENROLLED       (default; created on enrol)
//   - WITHDRAWN      (admin withdrew; cascade from student.withdraw)
//   - GRADUATED      (admin graduated; cascade from student.graduate)
//   - TRANSFERRED    (back-fill / manual PATCH; Phase 2 workflow)
//   - PROMOTED       (back-fill / manual PATCH; Phase 2/3 promotion engine)
//   - REPEATED       (back-fill / manual PATCH; Phase 2/3 promotion engine)
//
// No graduatedAt column — derived from updatedAt for the rare case the
// Phase 2 transcript module needs an explicit moment. Captured in
// docs/deferred.md as a Phase-2-trigger.

model Enrollment {
  id                String           @id @default(uuid())
  schoolId          String           @map("school_id")
  studentId         String           @map("student_id")
  termId            String           @map("term_id")
  academicYearId    String           @map("academic_year_id") // denormalised from term; MUST equal term.academic_year_id
  classArmId        String           @map("class_arm_id")
  status            EnrollmentStatus @default(ENROLLED)
  enrolledAt        DateTime         @default(now()) @map("enrolled_at")
  transferredAt     DateTime?        @map("transferred_at")
  withdrawnAt       DateTime?        @map("withdrawn_at")
  promotedFromArmId String?          @map("promoted_from_arm_id") // optional pointer to a previous term's arm (mid-year transfer or year promotion)
  notes             String?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term         Term         @relation(fields: [termId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  classArm     ClassArm     @relation(fields: [classArmId], references: [id], onDelete: Cascade)

  @@unique([schoolId, studentId, termId]) // one row per student per term
  @@index([schoolId])
  @@index([classArmId])
  @@index([schoolId, termId])
  @@index([schoolId, academicYearId])
  @@map("enrollments")
}

enum EnrollmentStatus {
  ENROLLED
  TRANSFERRED
  PROMOTED
  REPEATED
  WITHDRAWN
  GRADUATED
}

// ---------- Staff (Phase 1 / Slice 10) ----------
//
// TeacherProfile is the HR record for a User who holds the teacher role.
// 1:1 with User (userId @unique). Created explicitly by an admin AFTER the
// teacher accepts their invitation (Q2 lifecycle, locked 2026-05-30):
//   - The invitation-accept path is untouched — no profile is auto-created.
//   - `POST /teacher-profiles { userId, staffNumber, ... }` materialises it
//     with a real, admin-entered staffNumber.
//   - The teacher CSV import (slice 10 cp2) creates Invitations only; it does
//     NOT import profile fields (deferred — the Invitation row can't carry
//     them per phase-1.md:478, and acceptance #7 only requires invite-create).
//
// `joinedAt` is the pinned spec shape: a plain DateTime @default(now()), i.e.
// the moment the profile row was created — NOT an admin-entered hire date.
// A real `hireDate DATE` is Phase 3 payroll territory (alongside BVN capture,
// deferred at phase-1.md:1234). Kept as joinedAt per the locked design.
//
// Two unique constraints (userId, and (schoolId, staffNumber)) — the service
// pre-checks both before insert so it can return precise 409 codes; under
// FORCE RLS the P2002 constraint name is stripped, so we cannot discriminate
// from the error alone (see the RLS-hides-constraint-name note in CLAUDE.md).
//
// onDelete: Cascade — deleting the User drops the profile. In practice users
// are soft-deleted (isActive=false), so this fires only on a real hard delete.
model TeacherProfile {
  id             String   @id @default(uuid())
  schoolId       String   @map("school_id")
  userId         String   @unique @map("user_id") // 1:1 with User
  staffNumber    String   @map("staff_number") // unique per school; free-text in Phase 1
  qualifications String? // free-text in Phase 1; structured array in Phase 3 payroll
  specialty      String? // e.g. "Mathematics"
  nutNumber      String?  @map("nut_number") // Nigerian Union of Teachers number (optional)
  joinedAt       DateTime @default(now()) @map("joined_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([schoolId, staffNumber])
  @@index([schoolId])
  @@map("teacher_profiles")
}
