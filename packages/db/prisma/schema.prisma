// School Kit — Prisma schema (Phase 0)
//
// Models below mirror docs/modules/phase-0.md verbatim. Tenancy is enforced at
// the Postgres layer via RLS (see packages/db/prisma/policies/phase-0.sql) and
// at the application layer via withTenant() (see src/tenant-client.ts).

generator client {
  provider        = "prisma-client-js"
  // Generated client lives inside this package, gitignored. Sits as a
  // sibling of src/ so that compiled dist/*.js can require it via the same
  // relative path source uses (../generated/client).
  output          = "../generated/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // Migrations run as the privileged DB owner (school_kit). The runtime client
  // uses `url` and connects as `app_user`, which cannot bypass RLS.
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector"), uuidOssp(map: "uuid-ossp")]
}

// ---------- Tenancy ----------

model School {
  id             String       @id @default(uuid())
  name           String
  slug           String       @unique // for subdomains: <slug>.schoolkit.ng
  motto          String?
  logoUrl        String?      @map("logo_url")
  address        String?
  phone          String?
  email          String?
  primaryColor   String?      @map("primary_color")
  status         SchoolStatus @default(ONBOARDING)
  onboardingStep Int          @default(0) @map("onboarding_step")
  ndprConsent    Boolean      @default(false) @map("ndpr_consent")
  ndprConsentAt  DateTime?    @map("ndpr_consent_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  branches    Branch[]
  users       User[]
  invitations Invitation[]

  @@map("schools")
}

enum SchoolStatus {
  ONBOARDING
  ACTIVE
  SUSPENDED
  ARCHIVED
}

model Branch {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  name      String
  address   String?
  isMain    Boolean  @default(false) @map("is_main")
  createdAt DateTime @default(now()) @map("created_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("branches")
}

// ---------- Identity ----------

model User {
  id            String    @id @default(uuid())
  schoolId      String    @map("school_id")
  email         String?   @unique
  phone         String?   @unique
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  passwordHash  String?   @map("password_hash")
  isActive      Boolean   @default(true) @map("is_active")
  emailVerified Boolean   @default(false) @map("email_verified")
  phoneVerified Boolean   @default(false) @map("phone_verified")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  school   School     @relation(fields: [schoolId], references: [id])
  roles    UserRole[]
  sessions Session[]

  // Phase 1 / Slice 3 — back-relation to ClassArm.classTeacherId (the form
  // teacher). Named relation to disambiguate from the slice-11 teacher-
  // subject assignment edge below — both are User-to-teaching relations and
  // Prisma needs explicit names once a model has more than one relation set.
  classTeacherArms ClassArm[] @relation("ClassTeacherArms")

  // Phase 1 / Slice 10 — 1:1 HR profile for users who hold the teacher role.
  // Optional because most users (owner, admin) never get one, and a teacher
  // exists as a User the moment they accept their invitation; the profile is
  // created explicitly by an admin afterwards (Q2 lifecycle, locked
  // 2026-05-30 — no auto-create on accept).
  teacherProfile TeacherProfile?

  // Phase 1 / Slice 11 — subject-teaching assignments (this user teaches a
  // subject in a class arm for a year/term). Distinct from classTeacherArms
  // above: a form teacher owns the arm's register; a subject teacher teaches
  // one subject to it. The named relation pairs with TeacherAssignment.teacher.
  teacherAssignments TeacherAssignment[] @relation("TeacherSubjectAssignments")

  @@index([schoolId])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  schoolId    String?  @map("school_id") // null = system role (seeded)
  key         String // 'owner', 'admin', 'teacher', etc.
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  permissions Json     @default("[]") // string[] of permission keys, or ["*"]
  createdAt   DateTime @default(now()) @map("created_at")

  users UserRole[]

  @@unique([schoolId, key])
  @@map("roles")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Invitation {
  id         String    @id @default(uuid())
  schoolId   String    @map("school_id")
  email      String?
  phone      String?
  firstName  String?   @map("first_name")
  lastName   String?   @map("last_name")
  roleKey    String    @map("role_key")
  tokenHash  String    @unique @map("token_hash")
  invitedBy  String    @map("invited_by")
  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("invitations")
}

model AuditLog {
  id         String   @id @default(uuid())
  schoolId   String?  @map("school_id")
  userId     String?  @map("user_id")
  action     String // e.g. 'school.update', 'user.invite', 'academic-year.create'
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([schoolId, createdAt])
  @@map("audit_logs")
}

// ---------- Phase 1 / Slice 1 — Academic structure (year + term) ----------
//
// First Phase 1 slice. Two tables, both school-scoped, both under FORCE RLS.
// "Current year" / "current term" is modelled as an isCurrent flag enforced
// by partial unique indexes (added in the migration's raw SQL because
// Prisma's @@unique cannot express WHERE clauses). The service layer
// cascades setCurrentTerm → academic_year.is_current; that invariant is the
// only one the DB does not enforce, and the terms.service spec asserts it.

model AcademicYear {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  label     String // e.g. "2025/2026" — unique per school
  startDate DateTime @map("start_date") @db.Date // calendar dates, not moments — see CLAUDE.md
  endDate   DateTime @map("end_date") @db.Date
  isCurrent Boolean  @default(false) @map("is_current")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  terms              Term[]
  enrollments        Enrollment[] // Phase 1 / Slice 9 back-relation.
  teacherAssignments TeacherAssignment[] // Phase 1 / Slice 11 back-relation.

  @@unique([schoolId, label])
  @@index([schoolId])
  @@index([schoolId, isCurrent])
  @@map("academic_years")
}

model Term {
  id             String   @id @default(uuid())
  schoolId       String   @map("school_id")
  academicYearId String   @map("academic_year_id")
  sequence       Int // 1 | 2 | 3 — unique within a year
  name           String // "First Term", "Second Term", "Third Term"
  startDate      DateTime @map("start_date") @db.Date
  endDate        DateTime @map("end_date") @db.Date
  isCurrent      Boolean  @default(false) @map("is_current")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  academicYear       AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  enrollments        Enrollment[] // Phase 1 / Slice 9 back-relation.
  teacherAssignments TeacherAssignment[] // Phase 1 / Slice 11 back-relation (term-specific assignments).

  @@unique([academicYearId, sequence])
  @@index([schoolId])
  @@index([schoolId, isCurrent])
  @@map("terms")
}

// ---------- Phase 1 / Slice 2 — Class levels ----------
//
// Hybrid model: every new school is auto-seeded with the 14 standard Nigerian
// levels (KG 1/2, Primary 1–6, JSS 1–3, SSS 1–3) inside the signup
// transaction (see apps/api/src/modules/auth/auth.service.ts → signupOwner).
// Schools can then add custom levels, edit names, or toggle isActive.
//
// `code` is the stable per-school identifier (matching the seed) and backs
// the uniqueness constraint; `name` is the human-facing label and can be
// renamed freely. `orderIndex` drives sort order in the UI; duplicates are
// tolerated for schools that interleave custom levels (sort tie-breaks on
// name ASC). No partial unique index here — there is no "current level"
// concept; the current academic year/term carries that semantic.

model ClassLevel {
  id         String     @id @default(uuid())
  schoolId   String     @map("school_id")
  name       String // "KG 1", "Primary 4" — human-facing; renamable
  code       String // "kg1", "pri4" — stable per-school identifier (unique)
  stage      ClassStage // NURSERY | PRIMARY | JSS | SSS — coarse grouping
  orderIndex Int        @map("order_index") // sort order; seeded 1..14
  isActive   Boolean    @default(true) @map("is_active")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  // Phase 1 / Slice 3 back-relations.
  arms          ClassArm[]
  classSubjects ClassSubject[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([schoolId, orderIndex])
  @@map("class_levels")
}

enum ClassStage {
  NURSERY
  PRIMARY
  JSS
  SSS
}

// ---------- Phase 1 / Slice 3 — Class arms, subjects, class-subjects ----------
//
// Three models that complete the academic skeleton. ClassArm is the section
// under a ClassLevel ("JSS 1A", "JSS 1B"); Subject is the school-wide subject
// catalog; ClassSubject is the explicit many-to-many between ClassLevel and
// Subject (curriculum lives at the level, not the arm — all arms of JSS 1
// take the same set of subjects). All three carry their own school_id for
// direct-RLS isolation, matching the slice 1+2 pattern.
//
// classTeacherId on ClassArm references users.id (not teacher_profiles.id —
// that table arrives in slice 10). The dropdown stays empty until teachers
// have accepted invitations; the UI surfaces an "Invite a teacher" CTA per
// the spec risk note (docs/modules/phase-1.md → Risks and gotchas).

model ClassArm {
  id             String   @id @default(uuid())
  schoolId       String   @map("school_id")
  classLevelId   String   @map("class_level_id")
  name           String // "JSS 1A" — human-facing; renamable
  code           String // "jss1-a" — stable per-(school, level) identifier
  capacity       Int? // optional max headcount
  classTeacherId String?  @map("class_teacher_id") // FK → users.id (form teacher)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  classLevel         ClassLevel          @relation(fields: [classLevelId], references: [id], onDelete: Cascade)
  classTeacher       User?               @relation("ClassTeacherArms", fields: [classTeacherId], references: [id], onDelete: SetNull)
  enrollments        Enrollment[] // Phase 1 / Slice 9 back-relation.
  teacherAssignments TeacherAssignment[] // Phase 1 / Slice 11 back-relation (subject teachers of this arm).

  @@unique([schoolId, classLevelId, code])
  @@index([schoolId])
  @@index([classTeacherId])
  @@map("class_arms")
}

model Subject {
  id        String          @id @default(uuid())
  schoolId  String          @map("school_id")
  name      String // "Mathematics" — human-facing; renamable
  code      String // "math" — stable per-school identifier (unique)
  category  SubjectCategory @default(CORE)
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  classSubjects      ClassSubject[]
  teacherAssignments TeacherAssignment[] // Phase 1 / Slice 11 back-relation.

  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("subjects")
}

enum SubjectCategory {
  CORE
  ELECTIVE
  VOCATIONAL
}

// Explicit join between ClassLevel and Subject. Explicit (not Prisma's
// implicit m-n) because we need our own school_id column for direct-RLS and
// our own `isCore` payload (curriculum metadata: e.g. Maths is core in JSS
// but may be elective in some SSS streams). No updatedAt — link membership
// is binary; toggling isCore is a single UPDATE without history.

model ClassSubject {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  classLevelId String   @map("class_level_id")
  subjectId    String   @map("subject_id")
  isCore       Boolean  @default(true) @map("is_core")
  createdAt    DateTime @default(now()) @map("created_at")

  classLevel ClassLevel @relation(fields: [classLevelId], references: [id], onDelete: Cascade)
  subject    Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([schoolId, classLevelId, subjectId])
  @@index([schoolId])
  @@index([subjectId])
  @@map("class_subjects")
}

// ---------- Phase 1 / Slice 4 — Students ----------
//
// First slice to model actual people. Student is the roster spine: CSV import
// (slices 6-8) and Enrollment (slice 9) both build on this table. The model is
// stripped of every relation that points at models that do not exist yet —
// StudentGuardian (slice 5), Enrollment (slice 9), MasteryRecord +
// AIInteractionLog (slice 12) — those back-relations are added by their own
// slices to keep this one purely additive.
//
// Class membership is intentionally NOT on Student. The spec locks per-term
// Enrollment as the only source of truth (docs/modules/phase-1.md → "Enrollment
// is per-TERM, not per-academic-year"); a denormalised currentClassArmId here
// would drift on every term boundary and break the join shape Phase 2 is built
// around.
//
// dateOfBirth uses @db.Date per CLAUDE.md's "calendar date vs moment" rule
// (also explicitly named in that rule). The spec text shows plain `DateTime`
// — that's a pre-convention oversight from before slice 1 locked the
// convention, reconciled in this slice's docs edit. Plain DateTime is kept
// for admittedAt/withdrawnAt/graduatedAt: those are events (when the
// transition happened), not calendar dates.
//
// admissionNumber is free-text required-unique-per-school (no auto-format,
// no school-configurable scheme in Phase 1 — deferred). The unique constraint
// is the ordinary @@unique form, not a partial index, since there's no
// "current" semantic on Student.

model Student {
  id              String        @id @default(uuid())
  schoolId        String        @map("school_id")
  admissionNumber String        @map("admission_number") // free-text, unique per school
  firstName       String        @map("first_name")
  middleName      String?       @map("middle_name")
  lastName        String        @map("last_name")
  dateOfBirth     DateTime      @map("date_of_birth") @db.Date // calendar date — see CLAUDE.md
  gender          Gender
  photoUrl        String?       @map("photo_url") // string only; upload UI deferred (Phase 2/4)
  address         String?
  phone           String?
  email           String?
  bloodGroup      String?       @map("blood_group")
  medicalNotes    String?       @map("medical_notes")
  religion        String?
  stateOfOrigin   String?       @map("state_of_origin")
  nationality     String        @default("Nigerian")
  status          StudentStatus @default(ACTIVE)
  admittedAt      DateTime      @default(now()) @map("admitted_at") // event moment
  withdrawnAt     DateTime?     @map("withdrawn_at") // event moment
  graduatedAt     DateTime?     @map("graduated_at") // event moment
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Slice 5 adds the StudentGuardian back-relation; slice 9 adds Enrollment;
  // slice 12 adds the two AI-foundation back-relations (tables sit empty in
  // Phase 1 — shape owned by Phase 5).
  guardians         StudentGuardian[]
  enrollments       Enrollment[]       // Phase 1 / Slice 9 back-relation.
  masteryRecords    MasteryRecord[]    // Phase 1 / Slice 12 back-relation.
  aiInteractionLogs AIInteractionLog[] // Phase 1 / Slice 12 back-relation.

  @@unique([schoolId, admissionNumber])
  @@index([schoolId])
  @@index([schoolId, status])
  @@index([schoolId, lastName, firstName]) // sorted roster scans
  @@map("students")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  WITHDRAWN
  GRADUATED
  SUSPENDED
}

// ---------- Phase 1 / Slice 5 — Guardians + student-guardian links ----------
//
// Guardian is a school-scoped person record (parent, sibling, NOK, etc.).
// Phase 1 is admin-managed: owners and admins create / edit / link / unlink.
// Parent AUTH and the parent-facing app are Phase 4 — guardians cannot log in
// yet, so there is no User row paired with a Guardian here.
//
// Two design choices worth flagging:
//
//   1. NO unique constraint on (school_id, phone) or (school_id, email). A
//      mother and father commonly share a household phone; a guardian with a
//      shared family inbox may legitimately appear against multiple students
//      under separate records (rare, but real). The (school_id, phone) index
//      backs the link-existing picker; uniqueness would block valid data.
//
//   2. isPrimary on StudentGuardian has no schema-level "only one per
//      student" rule — application enforces it (GuardiansService demotes
//      sibling links inside the same transaction). A partial unique index
//      would be the correct-by-construction guard, but it would also block
//      the demote-then-promote pattern unless wrapped in a DEFERRABLE
//      constraint, which Postgres only supports for UNIQUE on a regular
//      index, not a partial one. The service-layer rule is the only path.
//
// onDelete: Cascade on BOTH FKs of StudentGuardian — deleting a Student or
// a Guardian cleans up the links. Guardian deletion itself is gated by the
// service to refuse hard-delete while links exist, so the cascade is a
// belt-and-braces guard, not the primary unlink path.

model Guardian {
  id           String       @id @default(uuid())
  schoolId     String       @map("school_id")
  firstName    String       @map("first_name")
  lastName     String       @map("last_name")
  relationship Relationship
  phone        String // NOT globally unique — see header comment
  email        String?
  occupation   String?
  employer     String?
  address      String?
  notes        String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  students StudentGuardian[]

  @@index([schoolId])
  @@index([schoolId, phone]) // backs the link-existing picker's phone search
  @@map("guardians")
}

enum Relationship {
  FATHER
  MOTHER
  GUARDIAN
  UNCLE
  AUNT
  GRANDPARENT
  SIBLING
  OTHER
}

model StudentGuardian {
  id         String   @id @default(uuid())
  schoolId   String   @map("school_id") // denormalised for direct RLS
  studentId  String   @map("student_id")
  guardianId String   @map("guardian_id")
  isPrimary  Boolean  @default(false) @map("is_primary")
  canPickup  Boolean  @default(true) @map("can_pickup")
  createdAt  DateTime @default(now()) @map("created_at")

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@unique([studentId, guardianId]) // a guardian cannot link to the same student twice
  @@index([schoolId])
  @@index([guardianId]) // reverse lookup: a guardian's children
  @@map("student_guardians")
}

// ---------- Phase 1 / Slice 6 — CSV import bookkeeping ----------
//
// One row per import attempt. The row is the source of truth for the
// wizard UI; BullMQ's internal job state (waiting/active/failed) is
// implementation detail and NEVER reaches the API consumer. The state
// machine is:
//
//   PENDING ──mapping─▶ VALIDATING ──worker ok──▶ READY ──┐  (commit is slice 7+)
//      │                     │                              ▼
//      │ delete              │ retries exhausted        COMMITTING ─▶ COMPLETED
//      ▼                     ▼
//   (gone)                  FAILED  ◀─────────────────────  (worker fatal)
//
// `sourceFileUrl` is a storage path (driver-agnostic — R2 in prod,
// filesystem in dev) of the form `schools/<schoolId>/imports/<jobId>/source.csv`.
// The StorageService is responsible for constructing this path; the schema
// does not enforce its shape because the path is opaque to Postgres.
//
// `previewSnapshot` holds first 50 good + first 50 bad rows for the UI
// preview only — the full bad-rows download (and the slice-7 error report)
// re-stream the source CSV rather than store all bad rows in JSON, to
// avoid bloating this row for large mostly-bad uploads.
//
// `failedReason` is populated by the FailedJobEvent listener when BullMQ
// exhausts retries, or directly by the worker when it detects an
// unrecoverable error (missing source file, parser fatal, etc.). Surfaced
// to the admin on step 3 of the wizard.
//
// `createdBy` is the userId of the admin who initiated the upload; flows
// into job-data for the worker so audit rows (slice 7 commit) attribute
// to a real user without needing a request context.
//
// SECURITY DEFINER count stays at 4. Every import endpoint is post-
// authentication and post-tenant; the worker establishes tenant context
// from job.data.schoolId via withTenant() — see apps/api/src/common/queue/
// tenant-worker.ts for the wrapper that makes this invariant mechanical.
model ImportJob {
  id              String          @id @default(uuid())
  schoolId        String          @map("school_id")
  type            ImportJobType
  status          ImportJobStatus @default(PENDING)
  sourceFileUrl   String          @map("source_file_url")
  columnMapping   Json?           @map("column_mapping")
  totalRows       Int             @default(0) @map("total_rows")
  validRows       Int             @default(0) @map("valid_rows")
  invalidRows     Int             @default(0) @map("invalid_rows")
  committedRows   Int             @default(0) @map("committed_rows")
  errorReportUrl  String?         @map("error_report_url")
  previewSnapshot Json?           @map("preview_snapshot")
  failedReason    String?         @map("failed_reason")
  createdBy       String          @map("created_by")
  createdAt       DateTime        @default(now()) @map("created_at")
  completedAt     DateTime?       @map("completed_at")

  @@index([schoolId])
  @@index([schoolId, status])
  @@map("import_jobs")
}

enum ImportJobType {
  STUDENTS
  GUARDIANS
  TEACHERS
}

enum ImportJobStatus {
  PENDING
  VALIDATING
  READY
  COMMITTING
  COMPLETED
  FAILED
}

// ---------- Phase 1 / Slice 9 — Enrollment (per-term) ----------
//
// Per-term, not per-academic-year. One row per (school, student, term).
// Why per-term, locked at 2026-05-22 in Phase 1 planning (docs/modules/
// phase-1.md → "Enrollment is per-TERM, not per-academic-year"):
//   - Nigerian schools admit students mid-year. A second-term joiner
//     gets a second-term row and no first-term row — no fudging.
//   - Phase 2's term-scoped features (attendance, CA1/CA2/exam, report
//     cards) join cleanly to Enrollment without a "which arm were they
//     in this term" lookup table.
//   - Mid-year arm transfers manifest as the NEXT term's row in the
//     new arm; the old term's row stays as historical truth.
// Do NOT "simplify" this back to per-year — it breaks the join shape
// Phase 2 is designed around.
//
// academicYearId is denormalised from term.academicYearId for cheap
// "all students enrolled in 2025/2026" roster queries. The service
// layer resolves academicYearId from termId at write time; the API
// never accepts it from a request body. The columns must stay
// consistent — Phase 2 may add a CHECK constraint or trigger; Phase
// 1 keeps it as a service-layer invariant to ship.
//
// Status enum (six values; only ENROLLED + WITHDRAWN have workflows
// in slice 9, the others reachable via manual PATCH — see slice-9
// scope decision):
//   - ENROLLED       (default; created on enrol)
//   - WITHDRAWN      (admin withdrew; cascade from student.withdraw)
//   - GRADUATED      (admin graduated; cascade from student.graduate)
//   - TRANSFERRED    (back-fill / manual PATCH; Phase 2 workflow)
//   - PROMOTED       (back-fill / manual PATCH; Phase 2/3 promotion engine)
//   - REPEATED       (back-fill / manual PATCH; Phase 2/3 promotion engine)
//
// No graduatedAt column — derived from updatedAt for the rare case the
// Phase 2 transcript module needs an explicit moment. Captured in
// docs/deferred.md as a Phase-2-trigger.

model Enrollment {
  id                String           @id @default(uuid())
  schoolId          String           @map("school_id")
  studentId         String           @map("student_id")
  termId            String           @map("term_id")
  academicYearId    String           @map("academic_year_id") // denormalised from term; MUST equal term.academic_year_id
  classArmId        String           @map("class_arm_id")
  status            EnrollmentStatus @default(ENROLLED)
  enrolledAt        DateTime         @default(now()) @map("enrolled_at")
  transferredAt     DateTime?        @map("transferred_at")
  withdrawnAt       DateTime?        @map("withdrawn_at")
  promotedFromArmId String?          @map("promoted_from_arm_id") // optional pointer to a previous term's arm (mid-year transfer or year promotion)
  notes             String?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term         Term         @relation(fields: [termId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  classArm     ClassArm     @relation(fields: [classArmId], references: [id], onDelete: Cascade)

  @@unique([schoolId, studentId, termId]) // one row per student per term
  @@index([schoolId])
  @@index([classArmId])
  @@index([schoolId, termId])
  @@index([schoolId, academicYearId])
  @@map("enrollments")
}

enum EnrollmentStatus {
  ENROLLED
  TRANSFERRED
  PROMOTED
  REPEATED
  WITHDRAWN
  GRADUATED
}

// ---------- Staff (Phase 1 / Slice 10) ----------
//
// TeacherProfile is the HR record for a User who holds the teacher role.
// 1:1 with User (userId @unique). Created explicitly by an admin AFTER the
// teacher accepts their invitation (Q2 lifecycle, locked 2026-05-30):
//   - The invitation-accept path is untouched — no profile is auto-created.
//   - `POST /teacher-profiles { userId, staffNumber, ... }` materialises it
//     with a real, admin-entered staffNumber.
//   - The teacher CSV import (slice 10 cp2) creates Invitations only; it does
//     NOT import profile fields (deferred — the Invitation row can't carry
//     them per phase-1.md:478, and acceptance #7 only requires invite-create).
//
// `joinedAt` is the pinned spec shape: a plain DateTime @default(now()), i.e.
// the moment the profile row was created — NOT an admin-entered hire date.
// A real `hireDate DATE` is Phase 3 payroll territory (alongside BVN capture,
// deferred at phase-1.md:1234). Kept as joinedAt per the locked design.
//
// Two unique constraints (userId, and (schoolId, staffNumber)) — the service
// pre-checks both before insert so it can return precise 409 codes; under
// FORCE RLS the P2002 constraint name is stripped, so we cannot discriminate
// from the error alone (see the RLS-hides-constraint-name note in CLAUDE.md).
//
// onDelete: Cascade — deleting the User drops the profile. In practice users
// are soft-deleted (isActive=false), so this fires only on a real hard delete.
model TeacherProfile {
  id             String   @id @default(uuid())
  schoolId       String   @map("school_id")
  userId         String   @unique @map("user_id") // 1:1 with User
  staffNumber    String   @map("staff_number") // unique per school; free-text in Phase 1
  qualifications String? // free-text in Phase 1; structured array in Phase 3 payroll
  specialty      String? // e.g. "Mathematics"
  nutNumber      String?  @map("nut_number") // Nigerian Union of Teachers number (optional)
  joinedAt       DateTime @default(now()) @map("joined_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([schoolId, staffNumber])
  @@index([schoolId])
  @@map("teacher_profiles")
}

// ---------- Phase 1 / Slice 11 — TeacherAssignment ----------
//
// Records "teacher T teaches subject S in class arm A for year Y (optionally
// term-specific)". This is the data behind the teacher-scope filter that
// closes acceptance #9 — a teacher logging in sees only the arms + subjects
// they are assigned to (cp2), plus the arms where they are the form teacher
// (ClassArm.classTeacherId, slice 3/10) which the scope helper unions in.
//
// Shape (locked 2026-05-31): direct FKs to classArm + subject, NOT through
// ClassSubject. ClassSubject is (classLevel × subject) — curriculum at the
// LEVEL; a teacher teaches a specific ARM (JSS 1A, not "JSS 1" as a whole),
// so the assignment must reference the arm. academicYearId scopes the
// assignment to a year; termId is OPTIONAL — null means "the whole year",
// a set value means "this term only" (e.g. a relief teacher covering one
// term). Closest to candidate (c) in the plan, with year + optional-term
// scoping added.
//
// Co-teaching is ALLOWED by design (Q2, 2026-05-31): teacherId is part of
// the unique key, so two teachers can share the same (arm, subject, year,
// term). Supports lab/team teaching and mid-term relief. The unique only
// stops the SAME teacher being assigned twice to an identical tuple.
//
// CAVEAT — NULL term + the unique key: Postgres treats NULL as DISTINCT in a
// unique index, so two identical whole-year rows (termId = NULL) do NOT
// collide at the DB. The service therefore pre-checks for an existing
// identical active assignment (matching null term explicitly) and returns a
// clean 409 TEACHER_ALREADY_ASSIGNED; the P2002 catch is the backstop for
// the non-null race. See teacher-assignments.service.ts.
//
// Direct school_id column for the same cheap direct-RLS filter every Phase 1
// table uses — no join-through-parent EXISTS subquery. onDelete: Cascade on
// teacher/arm/subject/year (deleting any drops the assignment); SetNull on
// term so clearing a term-specific assignment's term degrades it to a
// whole-year row rather than vanishing.
//
// SECURITY DEFINER count stays at 4 — every endpoint is post-authentication
// and post-tenant; withTenant() covers all access.
model TeacherAssignment {
  id             String   @id @default(uuid())
  schoolId       String   @map("school_id")
  teacherId      String   @map("teacher_id") // FK → users.id
  classArmId     String   @map("class_arm_id")
  subjectId      String   @map("subject_id")
  academicYearId String   @map("academic_year_id")
  termId         String?  @map("term_id") // null = whole year; set = term-specific
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  teacher      User         @relation("TeacherSubjectAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  classArm     ClassArm     @relation(fields: [classArmId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  term         Term?        @relation(fields: [termId], references: [id], onDelete: SetNull)

  @@unique([schoolId, teacherId, classArmId, subjectId, academicYearId, termId])
  @@index([schoolId])
  @@index([teacherId])
  @@index([classArmId])
  @@index([schoolId, academicYearId])
  @@map("teacher_assignments")
}

// ---------- Phase 1 / Slice 12 — AI foundation (thin; semantics OWNED BY PHASE 5) ----------
//
// These two tables exist to lock in school_id + RLS + audit shape NOW so that
// when Phase 5 fills out the AI features we are NOT doing a live-data
// migration on a populated table. They sit EMPTY in Phase 1 — slice 12 is a
// hard gate against premature Phase-5 work, not a feature. Do not build
// against them in Phase 1.
//
// Deliberately omitted (Phase 5 owns these — adding them now pre-empts a
// decision the spec intentionally punts):
//   - MasteryRecord: NO score column (0-1 vs 0-100 vs letter is Phase 5), NO
//     time-decay field beyond updatedAt, NO source/origin column (tutor vs
//     assessment vs manual). status is free-text String now, an enum in
//     Phase 5; topicRef is a loose string so the grain (subject/topic/
//     objective) can be chosen later without a migration.
//   - AIInteractionLog: payload is an OPAQUE Json envelope whose structure is
//     Phase-5-owned. It MUST stay PII-free per CLAUDE.md AI hard rules (never
//     send student PII to the LLM; log opaque ids + class-level context only).
//     The inline-vs-R2 storage tradeoff (cost/PII/eval) is a Phase-5 decision
//     made when there is a real payload — not pre-built here.
//
// NAMING DRIFT (reconcile in Phase 5): ARCHITECTURE.md §5/§7 and CLAUDE.md's
// AI hard rules name the LLM-call log `AIGeneration`/`ai_generations`; this
// table is `AIInteractionLog`/`ai_interaction_logs`. Phase 5 MUST rename/
// absorb one into the other (or define the boundary between them) BEFORE
// building the claudeClient call-logger, so we don't end up with two
// overlapping tables. Tracked in docs/deferred.md.
//
// Both tables carry their OWN school_id (despite the studentId FK) → flat
// direct-column RLS, same cheap pattern as student_guardians (see
// docs/modules/phase-1.md "Note on student_guardians"). SECURITY DEFINER
// count stays at 4 — no endpoints, no pre-tenant access; the tables are only
// ever reached via withTenant once Phase 5 wires them up.

model MasteryRecord {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  studentId String   @map("student_id")
  topicRef  String   @map("topic_ref") // loose identifier; taxonomy owned by Phase 5
  status    String // free-text in Phase 1; enum in Phase 5
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([schoolId, studentId, topicRef])
  @@index([schoolId])
  @@index([studentId])
  @@map("mastery_records")
}

model AIInteractionLog {
  id         String   @id @default(uuid())
  schoolId   String   @map("school_id")
  studentId  String?  @map("student_id") // nullable: teacher-driven sessions exist too
  sessionRef String   @map("session_ref") // loose grouping identifier; shape owned by Phase 5
  payload    Json // raw envelope; structure owned by Phase 5; MUST stay PII-free
  createdAt  DateTime @default(now()) @map("created_at")

  student Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([schoolId, createdAt])
  @@index([studentId])
  @@map("ai_interaction_logs")
}

// ---------- Phase 2 / Slice 1 — Grading configuration ----------
//
// Three per-school config tables, all seeded with sensible WAEC-style defaults
// at school creation (signupOwner, same tx as the class-level seed) and fully
// editable thereafter. They carry their own school_id → flat direct-column RLS,
// the same cheap pattern as every Phase 1 table. See docs/modules/phase-2.md
// (Data model → Grading configuration) for the locked design.
//
// Exactly one scheme per school (the @@unique on school_id enforces it). Most
// Nigerian schools run a single CA1+CA2+Exam scheme across every subject;
// per-level / per-subject schemes are explicitly deferred (phase-2.md "What's
// deferred"). Defaults: CA1=20, CA2=20, Exam=60 (Σ=100) — see
// packages/db/src/seeds/grading.ts.
model GradingScheme {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  name      String // "WAEC-style (default)"
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  components GradingComponent[]

  @@unique([schoolId]) // one scheme per school
  @@map("grading_schemes")
}

// N rows per scheme (CA1, CA2, Project, Exam, Practical…). weight is an integer
// percent; the set of components for a school MUST sum to exactly 100. That
// invariant is enforced ATOMICALLY OVER THE WHOLE SET at the service layer
// (and the bulk-PUT Zod refine), NOT by a DB constraint — same call as Phase 1
// made for the enrollment academicYearId-consistency invariant. See
// grading.service.ts and docs/modules/phase-2.md "Hard rules → Weights sum to 100".
//
// The `scores AssessmentScore[]` back-relation landed in Phase 2 / Slice 2
// (alongside the AssessmentScore table). onDelete: Restrict on the score side
// blocks deleting a component that still has scores — a guard against orphaning
// entered marks (the freeze invariant in grading.service.ts is the friendlier,
// earlier gate; this FK is the DB backstop).
model GradingComponent {
  id         String   @id @default(uuid())
  schoolId   String   @map("school_id")
  schemeId   String   @map("scheme_id")
  key        String // "ca1","ca2","project","exam","practical" — stable per school
  label      String // "First CA", "Project"
  weight     Int // integer percent; Σ weight per scheme = 100
  orderIndex Int      @map("order_index") // display order, left→right in the gradebook grid
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  scheme GradingScheme     @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  scores AssessmentScore[]

  @@unique([schoolId, schemeId, key])
  @@index([schoolId])
  @@map("grading_components")
}

// Per-school letter ↔ score-range map. WAEC scale pre-populated at school
// creation; fully editable. Ranges are inclusive on both ends and must tile
// 0..100 without gaps or overlaps — a service-layer invariant (+ bulk-PUT Zod
// refine), not a DB constraint. Default bands A1..F9 — see
// packages/db/src/seeds/grading.ts.
model GradeBoundary {
  id         String   @id @default(uuid())
  schoolId   String   @map("school_id")
  letter     String // "A1","B2","B3","C4","C5","C6","D7","E8","F9"
  minScore   Int      @map("min_score") // inclusive, 0..100
  maxScore   Int      @map("max_score") // inclusive, 0..100
  remark     String? // "Excellent","Very Good",...
  orderIndex Int      @map("order_index")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([schoolId, letter])
  @@index([schoolId])
  @@map("grade_boundaries")
}

// ---------- Phase 2 / Slice 2 — Assessment + AssessmentScore ----------
//
// The academic record's source of truth (AssessmentScore) and its denormalized
// per-(student × subject × term) summary (Assessment). See docs/modules/
// phase-2.md (Data model → Assessment) for the locked design. Both carry their
// own school_id → flat direct-column RLS, like every Phase 1/2 table.
//
// AssessmentScore is the raw mark a teacher types. score ∈ [0, component.weight]
// (STRICT — validated at the DTO and re-validated against the LIVE component row
// in the service; the component's weight is the ceiling). The summary below is
// DERIVED from these rows and materialized in the SAME tx as the score write
// (phase-2.md Hard rules "Grades are computed server-side"). There is no FK
// between the two tables — they are joined by the composite
// (student, subject, term); the score's only enforced relation is to the
// grading component (we need its live weight to validate).
model AssessmentScore {
  id          String   @id @default(uuid())
  schoolId    String   @map("school_id")
  studentId   String   @map("student_id")
  subjectId   String   @map("subject_id")
  termId      String   @map("term_id")
  componentId String   @map("component_id")
  score       Int // 0..component.weight (strict; already-weighted units)
  enteredBy   String   @map("entered_by") // users.id (plain FK; mirrors ImportJob.createdBy — captures admin overrides)
  enteredAt   DateTime @default(now()) @map("entered_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  component GradingComponent @relation(fields: [componentId], references: [id], onDelete: Restrict)

  @@unique([schoolId, studentId, subjectId, termId, componentId])
  @@index([schoolId])
  @@index([schoolId, termId, subjectId])
  @@map("assessment_scores")
}

// Denormalized summary: one row per (student × subject × term). Materialized on
// score entry (and re-materialized on the slice-4 aggregation pass) — NOT
// live-rendered — so the gradebook and report card read one row per cell.
//   totalScore      = EXACT Σ (AssessmentScore.score) over the entered
//                     components, 0..100 (no averaging/rounding/extrapolation —
//                     the load-bearing invariant slice 4 ranks against)
//   letterGrade     = resolved from GradeBoundary at compute time (nullable: a
//                     pathological boundary gap would leave it null)
//   classArmId      = denormalized from the student's Enrollment for the term
//                     (score entry rejects a student with no enrollment)
//   subjectPosition / classPosition  = LEFT NULL by slice 2; slice 4 computes
//                     them in the explicit aggregation pass (positions depend on
//                     every other student's total, so they are not a per-write
//                     side effect).
//   subjectSignedOffAt/By  = the subject teacher's per-(student × subject)
//                     sign-off. In slice 2 a score POST/PATCH CLEARS this (the
//                     implicit unlock); slice 6 owns the arm-state workflow gate.
model Assessment {
  id                 String    @id @default(uuid())
  schoolId           String    @map("school_id")
  studentId          String    @map("student_id")
  subjectId          String    @map("subject_id")
  termId             String    @map("term_id")
  academicYearId     String    @map("academic_year_id") // denormalized from term
  classArmId         String    @map("class_arm_id") // denormalized from enrollment for position scans
  totalScore         Int       @map("total_score") // 0..100
  letterGrade        String?   @map("letter_grade")
  remark             String?
  subjectPosition    Int?      @map("subject_position")
  classPosition      Int?      @map("class_position")
  subjectComment     String?   @map("subject_comment") // per-subject; AI-hook-ready (Phase 5), plain text
  subjectSignedOffAt DateTime? @map("subject_signed_off_at")
  subjectSignedOffBy String?   @map("subject_signed_off_by") // users.id
  computedAt         DateTime  @map("computed_at") // MATERIALIZATION stamp (set on score entry)
  // POSITIONS stamp (Phase 2 / Slice 4) — set by the aggregation pass when it
  // writes subjectPosition/classPosition. Distinct from computedAt (which is the
  // score-materialization moment); the status endpoint sources max() of this.
  positionsComputedAt DateTime? @map("positions_computed_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@unique([schoolId, studentId, subjectId, termId])
  @@index([schoolId])
  @@index([schoolId, termId, subjectId, classArmId]) // position scans
  @@index([schoolId, classArmId, termId])
  @@map("assessments")
}

// ---------- Phase 2 / Slice 5 — Report card ----------
//
// Materialized artifact, NOT live-rendered. One row per (student × term). The
// build pass (POST /report-cards/arm/build) runs the slice-4 full aggregation
// in-tx, then snapshots the term's rollup onto this row so the PDF reads a
// FROZEN rollup (not a live recompute). Carries the workflow state (slice 6
// drives the state machine; slice 5 only ever creates DRAFT), the three
// free-text comment grains, and the R2 pointer to the rendered PDF (slice 5 cp2
// renders; pdfStatus tracks it).
//
// overallAverage is an Int in hundredths (7350 = 73.50%) — the money/kobo rule
// applied to averages, no Float in grade math. overallPosition mirrors the
// student's Assessment.classPosition (denormalized here for the PDF footer).
// principalNote is per-arm-term, written once and denormalized identically onto
// every card in the arm (slice 6). Carries its own school_id → flat
// direct-column RLS, like every Phase 1/2 table.
model ReportCard {
  id                  String              @id @default(uuid())
  schoolId            String              @map("school_id")
  studentId           String              @map("student_id")
  termId              String              @map("term_id")
  academicYearId      String              @map("academic_year_id")
  classArmId          String              @map("class_arm_id")
  status              ReportCardStatus    @default(DRAFT)
  overallTotal        Int?                @map("overall_total") // Σ subject totals
  overallAverage      Int?                @map("overall_average") // avg × 100 (hundredths), no Float
  overallPosition     Int?                @map("overall_position") // = student's Assessment.classPosition
  subjectsCount       Int?                @map("subjects_count")
  formTeacherComment  String?             @map("form_teacher_comment") // per student-term; AI-hook-ready (Phase 5)
  principalNote       String?             @map("principal_note") // per arm-term; AI-hook-ready (Phase 5)
  formReviewedAt      DateTime?           @map("form_reviewed_at")
  formReviewedBy      String?             @map("form_reviewed_by") // users.id
  principalApprovedAt DateTime?           @map("principal_approved_at")
  principalApprovedBy String?             @map("principal_approved_by") // users.id
  releasedAt          DateTime?           @map("released_at")
  pdfStatus           ReportCardPdfStatus @default(PENDING) @map("pdf_status")
  artifactUrl         String?             @map("artifact_url") // R2: schools/<id>/report-cards/<termId>/<studentId>.pdf
  generatedAt         DateTime?           @map("generated_at")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  @@unique([schoolId, studentId, termId])
  @@index([schoolId])
  @@index([schoolId, classArmId, termId, status])
  @@map("report_cards")
}

enum ReportCardStatus {
  DRAFT // created; scores may still be changing
  SUBJECT_REVIEWED // every subject for the arm signed off by its subject teacher
  FORM_REVIEWED // form teacher reviewed the arm + wrote form comments
  PRINCIPAL_APPROVED // principal approved the arm
  RELEASED // parent-visible; PDF materialized
}

enum ReportCardPdfStatus {
  PENDING // not yet enqueued / awaiting render
  GENERATING // BullMQ job running Puppeteer
  GENERATED // artifactUrl populated
  FAILED // render failed; retryable
}
