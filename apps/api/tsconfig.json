{
  "extends": "@school-kit/config/tsconfig.node.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": "./",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "strict": false,
    "noUncheckedIndexedAccess": false,
    "types": ["node", "multer"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
