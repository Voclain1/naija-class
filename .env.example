# School Kit — environment template
# Copy to .env and fill in real values. Never commit .env.

# ---------- Core ----------
NODE_ENV=development

# ---------- Database ----------
# Local dev uses docker-compose (see docker-compose.yml). Prod = Neon/Supabase.
# Runtime connection — non-privileged role that cannot bypass RLS.
DATABASE_URL=postgresql://app_user:app_user@localhost:5432/school_kit?schema=public
# Migrations run as the DB owner (superuser). DO NOT use this for runtime queries.
DIRECT_URL=postgresql://school_kit:school_kit@localhost:5432/school_kit?schema=public

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- Auth ----------
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3001

# ---------- API ----------
API_PORT=4000
API_URL=http://localhost:4000
# CORS allow-list for the API. Explicit origins (not "*"). Browser will
# block any cross-origin request from an origin not matching one of these.
# Override in prod to the deployed origins.
CORS_ORIGIN=http://localhost:3001
# Phase 4 — the apps/portal origin. Optional (filter(Boolean) in main.ts), so
# a deploy without this set yet doesn't break the existing web origin above.
CORS_ORIGIN_PORTAL=http://localhost:3002
# Origin the API uses when constructing user-facing URLs that get emailed or
# SMS'd out (invitation accept links, password reset links). The API never
# follows these URLs — it only builds them. Must be set in prod; dev default
# (http://localhost:3001) matches the web dev port.
WEB_BASE_URL=http://localhost:3001

# ---------- Render worker (Tier 2) ----------
# URL the API calls (fire-and-forget GET /health) after releasing report cards
# to wake the stopped Fly machine before BullMQ jobs process. Leave blank
# in local dev — the render worker runs in-process via ReportCardRenderModule.
# In staging/prod set to the internal Fly URL:
#   http://school-kit-render-worker.internal:4001
RENDER_WORKER_URL=
# Port the render worker HTTP listener binds to. Defaults to 4001 in code.
RENDER_WORKER_PORT=4001

# ---------- Web (Next.js) ----------
# Public — exposed to the browser. Points the apps/web fetch client at the
# NestJS API's /api/v1 base path. Must include the /api/v1 suffix.
# apps/portal (Phase 4) reuses this same var — both frontends hit the same API.
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ---------- AI ----------
ANTHROPIC_API_KEY=sk-ant-replace-me

# ---------- Payments ----------
PAYSTACK_SECRET_KEY=sk_test_replace_me
PAYSTACK_PUBLIC_KEY=pk_test_replace_me

# ---------- BVN encryption (Phase 3 / Slice 12) ----------
# Symmetric key for pgcrypto pgp_sym_encrypt/pgp_sym_decrypt, delivered to
# Postgres per-transaction via `SET LOCAL app.bvn_key` (see BvnService).
# Generate with: openssl rand -hex 32
# Key loss = data loss — BVNs cannot be recovered if this is destroyed;
# schools would need to re-enter them. See docs/modules/phase-3.md §7.
BVN_ENCRYPTION_KEY=replace-me-with-openssl-rand-hex-32

# ---------- SMS / WhatsApp ----------
TERMII_API_KEY=replace-me
TERMII_SENDER_ID=SchoolKit

# ---------- Email ----------
RESEND_API_KEY=re_replace_me

# ---------- Storage (Cloudflare R2) ----------
R2_ACCOUNT_ID=replace-me
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_BUCKET=school-kit-dev

# ---------- Monitoring ----------
# Sentry — two separate projects, two DSNs. Blank = SDK disabled (no-op).
# Backend project (Node) DSN. Pull from Sentry → school-kit-api → Client Keys.
SENTRY_DSN_API=
# Web project (Next.js) DSN. NEXT_PUBLIC_ because the browser needs it.
NEXT_PUBLIC_SENTRY_DSN=
# Environment tag attached to every Sentry event. Defaults to NODE_ENV when
# unset. Set explicitly to distinguish staging from prod (both run with
# NODE_ENV=production but should land in separate Sentry environments).
SENTRY_ENVIRONMENT=development
# Sentry CLI auth token — required only for source map uploads in CI (cp4).
# Generate at https://sentry.io/settings/account/api/auth-tokens/
# Scope: project:releases + org:read. Never needed at runtime.
SENTRY_AUTH_TOKEN=
# PostHog — single project, browser-side capture only in Phase 0.
# NEXT_PUBLIC_ because the SDK runs in the browser. Blank = SDK disabled.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
